# Copy to .env and fill in values (or set via docker-compose environment)

DATABASE_URL=postgresql+asyncpg://ivdrive:CHANGE_ME@localhost:5432/ivdrive
VALKEY_URL=valkey://:CHANGE_ME@localhost:6379/0

JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
ENCRYPTION_KEY=CHANGE_ME_TO_BASE64_32_BYTE_KEY

CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=info

# When true, log each statistics/overview API request (route, params, result count) to container stdout (docker logs)
# STATISTICS_QUERY_DEBUG=true

# ─── Škoda Connect integration ────────────────────────────────
SKODA_BASE_URL=CHANGE_ME
SKODA_AUTH_CLIENT_ID=CHANGE_ME
SKODA_AUTH_REDIRECT_URI=CHANGE_ME

# ─── AI Assistant (chat LLM + RAG embeddings) ─────────────────
# GEMINI_API_KEY is required for semantic embeddings (gemini-embedding-001) and
# the admin embedding backfill; without it embeddings fall back to a hash.
MINIMAX_API_KEY=CHANGE_ME
GEMINI_API_KEY=CHANGE_ME

# ─── RAG embedding worker (collector) ─────────────────────────
EMBEDDING_WORKER_ENABLED=true
EMBEDDING_WORKER_POLL_INTERVAL_SECONDS=300
EMBEDDING_WORKER_BATCH_SIZE=50
EMBEDDING_WORKER_MAX_ATTEMPTS=3

# ─── Object storage (conversation session backups) ────────────
USE_S3_STORAGE=true
CONVERSATION_SESSIONS_BUCKET=ivdrive-conversation-sessions
S3_ENDPOINT=CHANGE_ME
S3_BUCKET=CHANGE_ME
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
